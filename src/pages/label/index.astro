---
import Base from '../../layouts/Base.astro';
import { entity, LABEL_NAME, CANONICAL_NAME } from '../../lib/entity';
import { organizationLd, websiteLd, musicGroupLd, breadcrumbLd, graph } from '../../lib/jsonld';
import VelvetBand from '../../components/VelvetBand.astro';
import featured from '../../data/featured.json';

// The label story, in full — moved off the front door so the room can speak for itself. Anyone
// who wants the "who/what" clicks Label and gets all of it.
const crate = (featured as any[]).filter((r) => r.cover);
const hero = (featured as any[]).find((r) => r.slug === 'hate-fuck') ?? crate[0];
const releaseCount = 72;

const title = `${LABEL_NAME} — independent record label`;
const description = `${LABEL_NAME} is an independent Canadian record label, home of ${CANONICAL_NAME}.`;
const jsonld = graph([
  organizationLd(),
  websiteLd(),
  musicGroupLd(),
  breadcrumbLd([{ name: LABEL_NAME, path: '/label/' }]),
]);
---

<Base title={title} description={description} path="/label/" jsonld={jsonld}>
  <p class="eyebrow anim-up" style="animation-delay:0ms;">Independent record label · Montréal, Québec</p>
  <h1 class="anim-up" style="animation-delay:60ms;">{LABEL_NAME}</h1>
  <p class="lede anim-up" style="animation-delay:140ms;">
    Independent Canadian record label. Home of <a href="/lucius-p-thundercat/">{CANONICAL_NAME}</a> — {releaseCount} releases, catalogued SVR-001 onward.
  </p>
  <p class="anim-up" style="animation-delay:200ms;max-width:42rem;">
    {LABEL_NAME} is a Montréal independent label built around a single deep catalogue — {releaseCount}
    releases and counting, every one numbered from SVR-001. The music lives in the
    <a href="/">Listening Room</a>; the story of who makes it is on the <a href="/lucius-p-thundercat/">artist page</a>.
  </p>

  <VelvetBand label="Silk Velvet Records" />

  <h2>Roster</h2>
  <a class="roster-card" href="/lucius-p-thundercat/">
    {hero?.cover && <span class="art"><img src={hero.cover} alt={`${CANONICAL_NAME} — ${hero.title} cover art`} width="128" height="128" /></span>}
    <span>
      <span class="r-name">{CANONICAL_NAME}</span>
      <span class="r-meta">{entity.identityUmbrella} · active since 2016 · {releaseCount} releases</span>
      <span class="r-link">View artist →</span>
    </span>
  </a>
</Base>
