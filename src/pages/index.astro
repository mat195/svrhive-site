---
import Base from '../layouts/Base.astro';
import { LABEL_NAME, CANONICAL_NAME } from '../lib/entity';
import { organizationLd, websiteLd, musicGroupLd, breadcrumbLd, graph } from '../lib/jsonld';
import ListeningRoom from '../components/ListeningRoom.astro';

// The front door IS the room. No intro copy, no headline, no tagline — someone lands and is
// immediately looking at a real crate of records in a warm, lived-in room, with nothing to read
// first, just something to touch. The label story lives in full on /label/. SEO/meta + the
// label↔artist schema anchor stay in the <head> (invisible), so structured data is unaffected.
const title = `${LABEL_NAME} — home of ${CANONICAL_NAME}`;
const description = `${LABEL_NAME}: independent Canadian record label, home of ${CANONICAL_NAME}. Pull a record, drop the needle, hear it.`;
const jsonld = graph([
  organizationLd(),
  websiteLd(),
  musicGroupLd(),
  breadcrumbLd([{ name: LABEL_NAME, path: '/' }]),
]);
---

<Base title={title} description={description} path="/" jsonld={jsonld}>
  <div class="room-home">
    <ListeningRoom />
  </div>
</Base>
