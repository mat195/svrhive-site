---
import Base from '../layouts/Base.astro';
import { LABEL_NAME, CANONICAL_NAME } from '../lib/entity';
import { organizationLd, websiteLd, musicGroupLd, breadcrumbLd, graph } from '../lib/jsonld';
import ListeningRoom from '../components/ListeningRoom.astro';

// The Listen page IS the homepage (root). It opens on a short label framing — the copy folded in
// from the retired /label/ page — then the interactive vinyl crate, which now lives on a velvet
// section directly below the hero (above the full discography), so the "press play" moment is one
// of the first things visible. The full catalogue list follows for deeper browsing.
const releaseCount = 72;

const title = `${LABEL_NAME} — home of ${CANONICAL_NAME}`;
const description = `${LABEL_NAME}: independent Canadian record label in Montréal, home of ${CANONICAL_NAME} — ${releaseCount} releases from a single deep Montréal catalogue. Pull a record and hear it.`;
const jsonld = graph([
  organizationLd(),
  websiteLd(),
  musicGroupLd(),
  breadcrumbLd([{ name: LABEL_NAME, path: '/' }]),
]);
---

<Base title={title} description={description} path="/" jsonld={jsonld}>
  <div class="room-home">
    <div class="room-intro">
      <p class="eyebrow anim-up" style="animation-delay:0ms;">Independent record label · Montréal, Québec</p>
      <h1 class="hero-fade hero-logo-h" style="animation-delay:60ms;"><img class="hero-logo" src="/assets/svr-glass-plate-logo.png?v=2" alt={LABEL_NAME} width="1423" height="1193" /></h1>
      <p class="lede anim-up" style="animation-delay:140ms;">
        Home of <a href="/lucius-p-thundercat/">{CANONICAL_NAME}</a> — {releaseCount} releases from a single deep Montréal catalogue.
      </p>
    </div>

    <ListeningRoom />
  </div>
  <script is:inline>
    // Scroll-driven velvet parallax for the hero logo — works on iOS (background-attachment:
    // fixed renders frozen there). Pans the seamless velvet as the page scrolls.
    (() => {
      const logo = document.querySelector('.hero-logo');
      if (!logo) return;
      let ticking = false;
      const update = () => { logo.style.backgroundPositionY = (window.scrollY * 0.45) + 'px'; ticking = false; };
      addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } }, { passive: true });
      update();
    })();
  </script>
</Base>
