---
import Base from '../layouts/Base.astro';
import { LABEL_NAME, CANONICAL_NAME } from '../lib/entity';
import { organizationLd, websiteLd, musicGroupLd, breadcrumbLd, graph } from '../lib/jsonld';
import ListeningRoom from '../components/ListeningRoom.astro';
import VelvetBand from '../components/VelvetBand.astro';
import featured from '../data/featured.json';

// The Listen page IS the homepage (root). It opens on a short label framing — the copy folded in
// from the retired /label/ page — then the interactive crate, then a velvet band carrying the
// flagship track's player. The flagship = the release with slug 'hate-fuck' (the long-standing
// "hero"), sourced from the data so the band's track id matches the rest of the site (no second
// source of truth); falls back to the known id only if the data ever drops it.
const releaseCount = 72;
const heroTrack = (featured as any[]).find((r) => r.slug === 'hate-fuck')?.trackId ?? '4Kp5EilxWm9lk7iWd63f3A';

const title = `${LABEL_NAME} — home of ${CANONICAL_NAME}`;
const description = `${LABEL_NAME}: independent Canadian record label in Montréal, home of ${CANONICAL_NAME} — ${releaseCount} releases, catalogued SVR-001 onward. Pull a record and hear it.`;
const jsonld = graph([
  organizationLd(),
  websiteLd(),
  musicGroupLd(),
  breadcrumbLd([{ name: LABEL_NAME, path: '/' }]),
]);
---

<Base title={title} description={description} path="/" jsonld={jsonld}>
  <div class="room-home">
    <div class="room-intro">
      <p class="eyebrow anim-up" style="animation-delay:0ms;">Independent record label · Montréal, Québec</p>
      <h1 class="anim-up" style="animation-delay:60ms;">{LABEL_NAME}</h1>
      <p class="lede anim-up" style="animation-delay:140ms;">
        Home of <a href="/lucius-p-thundercat/">{CANONICAL_NAME}</a> — {releaseCount} releases, catalogued SVR-001 onward. A Montréal independent label built around a single deep catalogue. Pull a record and hear it.
      </p>
    </div>

    <ListeningRoom />

    <VelvetBand trackId={heroTrack} height={280} />
  </div>
</Base>
