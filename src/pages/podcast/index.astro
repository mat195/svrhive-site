---
import Base from '../../layouts/Base.astro';
import { LABEL_NAME, absolute } from '../../lib/entity';
import { organizationLd, breadcrumbLd, clean, graph } from '../../lib/jsonld';
import podcast from '../../data/podcast.json';

const episodes = [...podcast.episodes].sort((a, b) => b.air_date.localeCompare(a.air_date));
const path = '/podcast/';
const title = `${podcast.channel.name} — Episode Guide`;
const description = `Episode guide for ${podcast.channel.name}: weekly album reviews and hip-hop conversation. Watch each episode and read the full transcript.`;

const seriesLd = clean({
  '@type': 'PodcastSeries',
  name: podcast.channel.name,
  url: absolute(path),
  sameAs: podcast.channel.url,
  publisher: { '@id': absolute('/#organization') },
});

const jsonld = graph([
  seriesLd,
  organizationLd(),
  breadcrumbLd([
    { name: LABEL_NAME, path: '/' },
    { name: podcast.channel.name, path },
  ]),
]);
---

<Base title={title} description={description} path={path} jsonld={jsonld}>
  <p class="eyebrow"><a href="/">{LABEL_NAME}</a> · Podcast</p>
  <h1>{podcast.channel.name}</h1>
  <p class="lede">Weekly album reviews and hip-hop conversation. Every episode below links to the video and a full, readable transcript.</p>

  <ul class="ep-guide">
    {episodes.map((ep) => (
      <li class="ep-row">
        <a class="ep-thumb" href={`/podcast/${ep.slug}/`} aria-label={`Episode ${ep.episode_number}: ${ep.title}`}>
          <img src={`https://i.ytimg.com/vi/${ep.youtube_video_id}/hqdefault.jpg`} alt={`${ep.title} — episode thumbnail`} width="480" height="360" loading="lazy" />
          <span class="ep-play" aria-hidden="true">▶</span>
        </a>
        <div class="ep-meta">
          <p class="ep-num mono">Ep {ep.episode_number} · <time datetime={ep.air_date}>{ep.air_date}</time></p>
          <h2 class="ep-title"><a href={`/podcast/${ep.slug}/`}>{ep.title}</a></h2>
          <p class="ep-syn">{ep.synopsis}</p>
          {ep.artists_covered?.length > 0 && (
            <p class="ep-artists mono"><span class="muted">Covered:</span> {ep.artists_covered.join(' · ')}</p>
          )}
        </div>
      </li>
    ))}
  </ul>
</Base>
