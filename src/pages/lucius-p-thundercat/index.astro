---
import Base from '../../layouts/Base.astro';
import { entity, LABEL_NAME, CANONICAL_NAME } from '../../lib/entity';
import { musicGroupLd, organizationLd, breadcrumbLd, graph } from '../../lib/jsonld';
import covers from '../../data/covers.json';

const title = `${CANONICAL_NAME} — ${entity.identityUmbrella} on ${LABEL_NAME}`;
const description = entity.bio100 ?? `${entity.primaryDescriptor}. Releases on ${LABEL_NAME}. ${entity.disambiguation}`;

const cov: Record<string, any> = covers as any;
// Merge cover art + catalog number + streams onto each release; releases WITH a cover
// (harvested from Spotify) lead, sorted by real stream count.
const primary = entity.releases
  .filter((r) => (r.role ?? 'primary') === 'primary')
  .map((r) => ({ ...r, ...(cov[r.slug] ?? {}) }))
  .sort((a, b) => (b.streams ?? -1) - (a.streams ?? -1));
const featured = entity.releases.filter((r) => r.role === 'featured');
const fmt = (n?: number) => (n == null ? null : n >= 1000 ? `${(n / 1000).toFixed(n >= 100000 ? 0 : 1)}K streams` : `${n} streams`);
// Verified collaborators (per Spotify for Artists / entity master §6–§7) — liner-note run-in.
const collaborators = ['Project Pat', 'OG Maco', 'Che Noir', 'Skyzoo', 'Ransom', 'Add-2', 'Curtis Williams', 'Magi Merlin', 'Nick Nigh', 'King Mizery', 'Sunnie'];

const jsonld = graph([
  musicGroupLd(),
  organizationLd(),
  breadcrumbLd([
    { name: LABEL_NAME, path: '/' },
    { name: CANONICAL_NAME, path: '/lucius-p-thundercat/' },
  ]),
]);
---

<Base title={title} description={description} path="/lucius-p-thundercat/" jsonld={jsonld} ogType="profile">
  <p class="eyebrow">{entity.identityUmbrella} · {entity.location}</p>
  <h1>{CANONICAL_NAME}</h1>

  {entity.bio100 ? (
    <p class="lede">{entity.bio100}</p>
  ) : (
    <p class="lede">
      {CANONICAL_NAME} is a {entity.primaryDescriptor}, based in {entity.location} and
      releasing through <a href="/">{LABEL_NAME}</a>. He works feature-first —
      signature collaborations include &ldquo;Must Be Love&rdquo; with Magi Merlin, alongside recurring work with Sunnie.
    </p>
  )}

  {/* Disambiguation is a STRUCTURED field only (schema.org disambiguatingDescription
      + llms.txt); never rendered as visible prose. Locked 2026-07-07. */}

  <h2>Sound</h2>
  <ul class="stickers">
    {entity.genresCore.map((g) => <li>{g}</li>)}
  </ul>

  <h2>Notable collaborations</h2>
  <p class="credits">
    {collaborators.map((n, i) => (
      <>{i > 0 ? ', ' : ''}<span class="name">{n}</span></>
    ))}.
  </p>

  {primary.length > 0 && (
    <>
      <h2>Releases <span class="catno" style="margin-left:0.4rem;">by streams</span></h2>
      <ul class="sleeve-grid">
        {primary.map((r) => (
          <li>
            <a class="sleeve" href={`/lucius-p-thundercat/releases/${r.slug}/`}>
              {r.cover ? (
                <span class="art"><img src={r.cover} alt={`${r.title} cover art`} loading="lazy" width="300" height="300" /></span>
              ) : (
                <span class="art placeholder"><span class="catno">{r.catalog ?? 'SVR'}</span></span>
              )}
              <span class="meta">
                <span class="title">{r.title}</span>
                <span class="sub">
                  {r.catalog ?? ''}{r.catalog && r.year ? ' · ' : ''}{r.year ?? r.releaseDate ?? ''}
                  {fmt(r.streams) ? <> · <span class="streams">{fmt(r.streams)}</span></> : null}
                </span>
              </span>
            </a>
            {r.cover && r.streams != null && (
              <a class="sleeve-play" href={`/listen/#${r.slug}`}>▶ Play preview</a>
            )}
          </li>
        ))}
      </ul>
    </>
  )}

  {featured.length > 0 && (
    <>
      <h2>Featured appearances</h2>
      <ul class="linklist">
        {featured.map((r) => (
          <li>
            <a href={`/lucius-p-thundercat/releases/${r.slug}/`}>{r.title}</a>
            <span class="muted">{r.primaryArtist ?? 'guest feature'}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  {entity.links.length > 0 && (
    <>
      <h2>Listen &amp; follow</h2>
      <ul class="linklist">
        {entity.links.map((l) => (
          <li>
            <a href={l.url} rel="me noopener">{l.platform}</a>
          </li>
        ))}
      </ul>
    </>
  )}

  <p class="muted"><small>Released on <a href="/">{LABEL_NAME}</a>.</small></p>
</Base>
