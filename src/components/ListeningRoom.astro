---
// The Listening Room — the interactive crate + vinyl deck + full catalog list. Extracted so it
// can BE the front door (root) as well as living at a canonical URL. No intro copy here: the
// room speaks for itself. Any framing/heading is the host page's call.
import covers from '../data/covers.json';
import featuredSet from '../data/featured.json';

const cov: Record<string, any> = covers as any;
const featCats = new Set((featuredSet as any[]).map((f) => f.catalog));
// Featured (mat-confirmed-current, source: Mat 2026-07-07) leads; then the rest of the
// catalog, for the mood chips to dig through. Default crate view = the featured set.
const rest = Object.entries(cov).map(([slug, v]: any) => ({ slug, ...v }))
  .filter((r) => r.cover && r.albumId && !featCats.has(r.catalog));
const streamsSorted = rest.map((r) => r.streams ?? 0).concat((featuredSet as any[]).map((f) => f.streams ?? 0)).sort((a, b) => a - b);
const median = streamsSorted[Math.floor(streamsSorted.length / 2)] ?? 0;
const tag = (r: any, feat: boolean) => ({ ...r, feat, moods: [
  feat ? 'featured' : null,
  r.featured?.length ? 'feature' : null,
  (r.streams ?? 0) <= median ? 'deep' : 'essential',
].filter(Boolean) });
const records = [...(featuredSet as any[]).map((r) => tag(r, true)), ...rest.map((r) => tag(r, false))];
const CHIPS = [
  { id: 'featured', label: 'Featured' },
  { id: 'all', label: 'Everything' },
  { id: 'feature', label: 'Feature-heavy' },
  { id: 'deep', label: 'Deep cuts' },
];
const fmt = (n?: number) => (n == null ? '' : n >= 1000 ? `${(n / 1000).toFixed(n >= 100000 ? 0 : 1)}K streams` : `${n} streams`);
---

<section class="velvet-stage">
  <div class="velvet-stage-inner">
<div class="lr" data-reduced-safe>
  <div class="lr-chips" role="tablist" aria-label="Filter the crate">
    {CHIPS.map((c) => (
      <button class="lr-chip" data-mood={c.id} aria-pressed={c.id === 'all' ? 'true' : 'false'}>{c.label}</button>
    ))}
  </div>

  <div class="lr-crate-wrap">
    {/* FAN — filtered subsets (Featured / Feature-heavy / Deep cuts), small numbers, capped. */}
    <div id="lr-crate" class="lr-crate" aria-label="Record crate"></div>
    {/* WHEEL — the 360° round-spin selector for the full catalogue (Everything): a coverflow you
        drag/swipe through; the front cover is selected; tap it to drop the needle. */}
    <div id="lr-wheel" class="lr-wheel" hidden aria-label="Spin through the full catalogue" aria-roledescription="carousel">
      <button class="lr-wheel-arrow prev" type="button" aria-label="Previous record">‹</button>
      <div class="lr-wheel-track"></div>
      <button class="lr-wheel-arrow next" type="button" aria-label="Next record">›</button>
    </div>
    <div id="lr-wheel-label" class="lr-wheel-label" hidden><strong id="lr-wheel-title"></strong><span class="muted" id="lr-wheel-sub"></span></div>
    <button id="lr-pull" class="lr-pullbtn">Pull a record</button>
  </div>

  <div id="lr-stage" class="lr-stage" hidden>
    <div class="lr-deck">
      <div class="lr-turntable">
        <div id="lr-disc" class="lr-disc"><span id="lr-disc-label" class="lr-disc-label"></span></div>
        <div id="lr-sleeve" class="lr-stage-sleeve"><img id="lr-sleeve-img" src="" alt="" /></div>
        <svg class="lr-tonearm" viewBox="0 0 120 120" aria-hidden="true">
          <circle cx="98" cy="22" r="9" fill="#201826" stroke="#c9a86a" stroke-width="1.5"/>
          <g id="lr-arm" transform="rotate(-28 98 22)">
            <line x1="98" y1="22" x2="52" y2="72" stroke="#8d8496" stroke-width="3.2" stroke-linecap="round"/>
            <rect x="46" y="70" width="12" height="8" rx="1.5" fill="#c9a86a"/>
          </g>
        </svg>
      </div>
      <div class="lr-card">
        <span id="lr-catno" class="catno"></span>
        <h2 id="lr-title" style="margin:0.2rem 0 0.3rem;"></h2>
        <p id="lr-meta" class="mono" style="color:var(--static);font-size:0.8rem;margin:0 0 0.9rem;"></p>
        <div class="lr-actions">
          <button id="lr-another" class="lr-pullbtn sm">Pull another</button>
          <button id="lr-back" class="lr-textbtn">← Back to the crate</button>
        </div>
      </div>
    </div>
    {/* Embed fades in BELOW the vinyl (the platform's own track player). */}
    <div id="lr-embed" class="lr-embed"></div>
  </div>
</div>
  </div>
</section>

{/* Full list — rich rows (thumbnail + play), also the static fallback: every track is
    in the HTML before any JS runs (crawlers + no-JS get titles + Spotify links). */}
<h2 class="lr-fulltitle mono">The full crate</h2>
<ul class="lr-list">
  {records.map((r) => (
    <li class="lr-row" data-slug={r.slug}>
      <span class="lr-thumb">
        {r.cover
          ? <img src={r.cover} alt={`${r.title} cover art`} loading="lazy" width="72" height="72" />
          : <span class="lr-thumb-ph"><span class="catno">{r.catalog}</span></span>}
      </span>
      <span class="lr-row-main">
        <a class="lr-row-title" href={r.trackId ? `https://open.spotify.com/track/${r.trackId}` : `https://open.spotify.com/album/${r.albumId}`} target="_blank" rel="noopener">{r.title}</a>
        <span class="lr-row-sub"><span class="catno lr-row-cat">{r.catalog}</span> · {r.year}{r.featured?.length ? ` · feat. ${r.featured.join(', ')}` : ''}{r.streams ? ` · ${fmt(r.streams)}` : ''}</span>
      </span>
      <button class="lr-row-play" data-slug={r.slug} aria-label={`Play ${r.title}`} title="Play preview">▶</button>
    </li>
  ))}
</ul>

<script type="application/json" id="lr-data" set:html={JSON.stringify(records)}></script>
<script is:inline>
  const initListeningRoom = () => {
    const crateEl0 = document.getElementById('lr-crate');
    if (!crateEl0 || crateEl0.dataset.init) return; // not on this page, or already bound
    crateEl0.dataset.init = '1';
    const data = JSON.parse(document.getElementById('lr-data').textContent);
    const crate = document.getElementById('lr-crate');
    const stage = document.getElementById('lr-stage');
    const crateWrap = document.querySelector('.lr-crate-wrap');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let filtered = data.slice(); // front door opens on the FULL crate (Everything)
    let idleTimer = null, shuffleTimer = null;

    // Fan a SMALL, curated set (capped at 10 — anything larger uses the wheel). Spacing adapts to
    // the container so the fan always fits the viewport, never cut off on mobile.
    const FAN_CAP = 10;
    const fan = (list) => {
      list = list.slice(0, FAN_CAP);
      const n = list.length;
      const narrow = window.innerWidth < 560;
      const sleeveW = narrow ? 104 : 150;
      const cw = crate.clientWidth || (narrow ? window.innerWidth - 40 : 560);
      const fit = n > 1 ? (cw - sleeveW) / (n - 1) : 0;          // step that keeps the fan inside the box
      const step = Math.max(12, Math.min(narrow ? 30 : 40, fit)); // never wider than the container
      crate.innerHTML = list.map((r, i) => {
        const spread = Math.min(44, Math.max(12, n * 4));
        const rot = n > 1 ? (-spread / 2 + (i / (n - 1)) * spread) : 0;
        const x = (i - (n - 1) / 2) * step;
        const y = Math.abs(i - (n - 1) / 2) * 2;
        return `<button class="cr-sleeve" data-slug="${r.slug}" style="--rot:${rot.toFixed(1)}deg;--x:${x.toFixed(0)}px;--y:${y}px;z-index:${i}" aria-label="Pull ${r.title.replace(/"/g, '')}"><img src="${r.cover}" alt="${r.title.replace(/"/g, '')} cover art" loading="lazy"></button>`;
      }).join('');
    };

    // ── Round-spin wheel (coverflow) for the full catalogue ──────────────────────
    const wheel = document.getElementById('lr-wheel');
    const wheelTrack = wheel.querySelector('.lr-wheel-track');
    const wheelLabel = document.getElementById('lr-wheel-label');
    let wheelList = [], wheelIndex = 0;
    const clampW = (i) => Math.max(0, Math.min(wheelList.length - 1, i));
    const stepPx = () => (window.innerWidth < 560 ? 82 : 128);
    const positionWheel = () => {
      const narrow = window.innerWidth < 560;
      wheelTrack.querySelectorAll('.lr-wheel-cover').forEach((el) => {
        const off = (+el.dataset.idx) - wheelIndex, abs = Math.abs(off);
        if (abs > 3.2) { el.style.display = 'none'; return; }
        el.style.display = '';
        const scale = off === 0 ? (narrow ? 1.06 : 1.18) : Math.max(0.5, 1 - abs * 0.17);
        const rotY = Math.max(-58, Math.min(58, -off * 44));
        el.style.transform = `translateX(${(off * stepPx()).toFixed(1)}px) translateZ(${(-abs * 70).toFixed(0)}px) rotateY(${rotY.toFixed(1)}deg) scale(${scale.toFixed(3)})`;
        el.style.zIndex = String(100 - Math.round(abs * 10));
        el.style.opacity = String(abs > 2.4 ? 0.28 : 1);
        el.classList.toggle('front', Math.round(off) === 0);
      });
    };
    const updateWheelLabel = () => {
      const r = wheelList[Math.round(wheelIndex)]; if (!r) return;
      document.getElementById('lr-wheel-title').textContent = r.title;
      document.getElementById('lr-wheel-sub').textContent = ' · ' + [r.catalog, r.year].filter(Boolean).join(' · ');
    };
    const renderWheel = (list) => {
      wheelList = list; wheelIndex = 0;
      wheelTrack.innerHTML = list.map((r, i) => `<button class="lr-wheel-cover" type="button" data-slug="${r.slug}" data-idx="${i}" aria-label="${r.title.replace(/"/g, '')}"><img src="${r.cover}" alt="${r.title.replace(/"/g, '')} cover art" loading="lazy"></button>`).join('');
      positionWheel(); updateWheelLabel();
    };
    let dragX = null, dragStart = 0, moved = 0;
    wheel.addEventListener('pointerdown', (e) => { if (e.target.closest('.lr-wheel-arrow')) return; dragX = e.clientX; dragStart = wheelIndex; moved = 0; wheel.classList.add('dragging'); try { wheel.setPointerCapture(e.pointerId); } catch (_) {} });
    wheel.addEventListener('pointermove', (e) => { if (dragX == null) return; const dx = e.clientX - dragX; moved = Math.max(moved, Math.abs(dx)); wheelIndex = clampW(dragStart - dx / stepPx()); positionWheel(); });
    const endDrag = () => { if (dragX == null) return; dragX = null; wheel.classList.remove('dragging'); wheelIndex = clampW(Math.round(wheelIndex)); positionWheel(); updateWheelLabel(); };
    wheel.addEventListener('pointerup', endDrag);
    wheel.addEventListener('pointercancel', endDrag);
    wheelTrack.addEventListener('click', (e) => {
      const b = e.target.closest('.lr-wheel-cover'); if (!b || moved > 6) return; // a tap, not a drag
      const idx = +b.dataset.idx;
      if (idx === Math.round(wheelIndex)) pull(b.dataset.slug);       // front cover → drop the needle
      else { wheelIndex = idx; positionWheel(); updateWheelLabel(); } // side cover → bring it to front
    });
    wheel.querySelector('.prev').addEventListener('click', () => { wheelIndex = clampW(Math.round(wheelIndex) - 1); positionWheel(); updateWheelLabel(); });
    wheel.querySelector('.next').addEventListener('click', () => { wheelIndex = clampW(Math.round(wheelIndex) + 1); positionWheel(); updateWheelLabel(); });
    window.addEventListener('resize', () => { if (!wheel.hidden) positionWheel(); else if (!crate.hidden) fan(filtered.slice(0, FAN_CAP)); }, { passive: true });

    // Pull → the platform's OWN track player FADES IN below the vinyl (the Spotify iframe is the
    // audio; no Web Audio, no native taste). Track-level (embed/track/<id>) so a logged-in play
    // counts as a real stream — never an album/artist embed. A small toggle switches to Apple.
    const embed = document.getElementById('lr-embed');
    let currentRec = null;
    const platformIframe = (r, plat) => {
      if (plat === 'apple' && r.appleTrackId && r.appleAlbumId)
        return `<iframe class="lr-apple-embed" src="https://embed.music.apple.com/us/album/${r.appleAlbumId}?i=${r.appleTrackId}" height="175" frameborder="0" allow="autoplay *; encrypted-media *; clipboard-write" sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation" loading="lazy" title="Apple Music player"></iframe>`;
      const src = r.trackId ? `https://open.spotify.com/embed/track/${r.trackId}` : `https://open.spotify.com/embed/album/${r.albumId}`;
      return `<iframe class="lr-spotify-embed" src="${src}" width="100%" height="152" frameborder="0" allow="autoplay; encrypted-media; clipboard-write; fullscreen; picture-in-picture" loading="lazy" title="Spotify player"></iframe>`;
    };
    const renderEmbed = (r, plat) => {
      const hasApple = r.appleTrackId && r.appleAlbumId;
      let toggle = `<div class="lr-listen-on"><span class="lr-lo-label">Listen on</span>`
        + `<button class="lr-lo-btn ${plat === 'spotify' ? 'on' : ''}" data-plat="spotify" type="button">Spotify</button>`;
      if (hasApple) toggle += `<button class="lr-lo-btn ${plat === 'apple' ? 'on' : ''}" data-plat="apple" type="button">Apple Music</button>`;
      toggle += `</div>`;
      embed.innerHTML = toggle + platformIframe(r, plat);
    };
    const mountDeckPlayer = (r) => {
      currentRec = r;
      if (window.SVR) window.SVR.stop(); // the embed is the audio here — silence the native taste bar
      renderEmbed(r, 'spotify'); // auto-load Spotify (fades in); toggle switches platform
    };
    embed.addEventListener('click', (e) => {
      const btn = e.target.closest('.lr-lo-btn');
      if (!btn || !currentRec) return;
      renderEmbed(currentRec, btn.dataset.plat);
    });

    const pull = (slug) => {
      const r = (slug ? data.find((x) => x.slug === slug) : filtered[Math.floor(Math.random() * filtered.length)]);
      if (!r) return;
      stopIdle();
      document.getElementById('lr-catno').textContent = r.catalog || '';
      document.getElementById('lr-title').textContent = r.title;
      document.getElementById('lr-meta').textContent = [r.year, r.featured?.length ? 'feat. ' + r.featured.join(', ') : null, r.streams ? (r.streams >= 1000 ? (r.streams / 1000).toFixed(r.streams >= 1e5 ? 0 : 1) + 'K streams' : r.streams + ' streams') : null].filter(Boolean).join(' · ');
      document.getElementById('lr-disc-label').textContent = r.catalog || 'SVR';
      document.getElementById('lr-sleeve-img').src = r.cover;
      document.getElementById('lr-sleeve-img').alt = r.title + ' cover art';
      mountDeckPlayer(r);
      crateWrap.hidden = true; stage.hidden = false;
      stage.querySelector('.lr-deck').classList.remove('spun'); void stage.offsetWidth; stage.querySelector('.lr-deck').classList.add('spun');
      stage.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'center' });
    };

    const reset = () => { stage.hidden = true; crateWrap.hidden = false; if (window.SVR) window.SVR.stop(); embed.innerHTML = ''; startIdle(); };

    // Everything → the round-spin wheel; the named subsets → the small fan. Both feed pull().
    const applyFilter = (mood) => {
      const isAll = mood === 'all';
      crate.hidden = isAll; wheel.hidden = !isAll; wheelLabel.hidden = !isAll;
      const pullBtn = document.getElementById('lr-pull');
      if (isAll) {
        filtered = data.slice();
        renderWheel(filtered);
        pullBtn.textContent = 'Play this record';
        stopIdle();
      } else {
        filtered = data.filter((r) => r.moods.includes(mood));
        fan(filtered);
        pullBtn.textContent = 'Pull a record';
        startIdle();
      }
    };

    // idle "digging" auto-shuffle — fan mode only (off under reduced-motion or when the wheel is up)
    const startIdle = () => { if (reduced || !wheel.hidden) return; stopIdle(); idleTimer = setTimeout(() => { shuffleTimer = setInterval(() => { filtered = filtered.slice().sort(() => Math.random() - 0.5); fan(filtered); }, 2600); }, 10000); };
    const stopIdle = () => { clearTimeout(idleTimer); clearInterval(shuffleTimer); idleTimer = shuffleTimer = null; };

    crate.addEventListener('click', (e) => { const b = e.target.closest('.cr-sleeve'); if (b) pull(b.dataset.slug); });
    document.getElementById('lr-pull').addEventListener('click', () => {
      if (!wheel.hidden) { const r = wheelList[Math.round(wheelIndex)]; if (r) pull(r.slug); } // wheel: the front one
      else pull(); // fan: a random dig
    });
    document.getElementById('lr-another').addEventListener('click', () => pull());
    document.getElementById('lr-back').addEventListener('click', reset);
    document.querySelectorAll('.lr-chip').forEach((chip) => chip.addEventListener('click', () => {
      document.querySelectorAll('.lr-chip').forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true'); stopIdle(); applyFilter(chip.dataset.mood); startIdle();
    }));
    // Full-list rows: play button (or clicking the row) runs the same pull/spin/embed
    // sequence and scrolls up to the deck — no need to hunt for the sleeve in the crate.
    document.querySelectorAll('.lr-row-play').forEach((b) => b.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); pull(b.dataset.slug); }));
    document.querySelectorAll('.lr-row').forEach((row) => row.addEventListener('click', (e) => { if (e.target.closest('a')) return; pull(row.dataset.slug); }));
    ['pointermove', 'keydown', 'click'].forEach((ev) => document.querySelector('.lr').addEventListener(ev, () => { if (!shuffleTimer && stage.hidden) startIdle(); else if (shuffleTimer) { stopIdle(); startIdle(); } }, { passive: true }));

    applyFilter('all'); // front door opens on the round-spin wheel (the full catalogue)
    // deep link: /#slug (or /listen/#slug) auto-pulls that record (from artist-page "play preview")
    if (location.hash.length > 1) { const s = decodeURIComponent(location.hash.slice(1)); if (data.some((r) => r.slug === s)) pull(s); }
  };
  initListeningRoom();
  document.addEventListener('astro:page-load', initListeningRoom);
</script>
