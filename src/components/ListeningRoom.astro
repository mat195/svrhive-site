---
// The Listening Room — the interactive crate + vinyl deck + full catalog list. Extracted so it
// can BE the front door (root) as well as living at a canonical URL. No intro copy here: the
// room speaks for itself. Any framing/heading is the host page's call.
import covers from '../data/covers.json';
import featuredSet from '../data/featured.json';

const cov: Record<string, any> = covers as any;
const featCats = new Set((featuredSet as any[]).map((f) => f.catalog));
// Featured (mat-confirmed-current, source: Mat 2026-07-07) leads; then the rest of the
// catalog, for the mood chips to dig through. Default crate view = the featured set.
const rest = Object.entries(cov).map(([slug, v]: any) => ({ slug, ...v }))
  .filter((r) => r.cover && r.albumId && !featCats.has(r.catalog));
const streamsSorted = rest.map((r) => r.streams ?? 0).concat((featuredSet as any[]).map((f) => f.streams ?? 0)).sort((a, b) => a - b);
const median = streamsSorted[Math.floor(streamsSorted.length / 2)] ?? 0;
const tag = (r: any, feat: boolean) => ({ ...r, feat, moods: [
  feat ? 'featured' : null,
  r.featured?.length ? 'feature' : null,
  (r.streams ?? 0) <= median ? 'deep' : 'essential',
].filter(Boolean) });
const records = [...(featuredSet as any[]).map((r) => tag(r, true)), ...rest.map((r) => tag(r, false))];
const CHIPS = [
  { id: 'featured', label: 'Featured' },
  { id: 'all', label: 'Everything' },
  { id: 'feature', label: 'Feature-heavy' },
  { id: 'deep', label: 'Deep cuts' },
];
const fmt = (n?: number) => (n == null ? '' : n >= 1000 ? `${(n / 1000).toFixed(n >= 100000 ? 0 : 1)}K streams` : `${n} streams`);
---

<section class="velvet-stage">
  <div class="velvet-stage-inner">
<div class="lr lr-unified" data-reduced-safe>
  <div class="lr-main">
    {/* Filter tabs as a vertical side rail. Every tab drives the SAME wheel — only the subset changes. */}
    <div class="lr-rail" role="tablist" aria-label="Filter the records">
      {CHIPS.map((c) => (
        <button class="lr-chip" role="tab" data-mood={c.id} aria-pressed={c.id === 'all' ? 'true' : 'false'}>{c.label}</button>
      ))}
    </div>
    <div class="lr-wheelcol">
      {/* The rotary wheel — drag/swipe to spin, tap the front cover to play instantly (no button). */}
      <div id="lr-wheel" class="lr-wheel" tabindex="0" aria-label="Spin the records — drag to rotate, arrow keys to step, tap the front cover to play" aria-roledescription="carousel">
        <button class="lr-wheel-arrow prev" type="button" aria-label="Previous record">‹</button>
        <div class="lr-wheel-track"></div>
        <button class="lr-wheel-arrow next" type="button" aria-label="Next record">›</button>
      </div>
      {/* Player sits DIRECTLY beneath the wheel, in place — never a page swap. Track info lives in
          its header and tracks the front cover; the embed fills in when a cover is tapped. */}
      {/* Always-visible player. Idle when nothing plays; a cover-tap (or the record, or ▶) starts
          the 30s preview instantly. 'Full track' loads the Spotify/Apple embed (counts a stream). */}
      <div id="lr-player" class="lr-player">
        <div class="lr-player-body">
          <button class="lr-vinyl" id="lr-vinyl" type="button" aria-label="Play or pause">
            <span class="lr-vinyl-disc"><img id="lr-vinyl-cover" src="" alt="" /></span>
          </button>
          <div class="lr-player-main">
            <div class="lr-player-info">
              <strong id="lr-title" class="lr-player-title"></strong>
              <span id="lr-meta" class="muted mono"></span>
            </div>
            <div class="lr-transport">
              <button id="lr-playpause" class="lr-playpause" type="button" aria-label="Play">▶</button>
              <span class="lr-time" id="lr-cur">0:00</span>
              <div class="lr-scrub" id="lr-scrub" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0"><div class="lr-scrub-fill" id="lr-fill"></div></div>
              <span class="lr-time" id="lr-dur">0:30</span>
            </div>
            <div class="lr-full" id="lr-full"></div>
          </div>
        </div>
      </div>
      <audio id="lr-audio" preload="none"></audio>
    </div>
  </div>
</div>
  </div>
</section>

{/* Full list — rich rows (thumbnail + play), also the static fallback: every track is
    in the HTML before any JS runs (crawlers + no-JS get titles + Spotify links). */}
<h2 class="lr-fulltitle mono">The full crate</h2>
<ul class="lr-list">
  {records.map((r) => (
    <li class="lr-row" data-slug={r.slug}>
      <span class="lr-thumb">
        {r.cover
          ? <img src={r.cover} alt={`${r.title} cover art`} loading="lazy" width="72" height="72" />
          : <span class="lr-thumb-ph"><span class="lr-thumb-note">♪</span></span>}
      </span>
      <span class="lr-row-main">
        <a class="lr-row-title" href={r.trackId ? `https://open.spotify.com/track/${r.trackId}` : `https://open.spotify.com/album/${r.albumId}`} target="_blank" rel="noopener">{r.title}</a>
        <span class="lr-row-sub">{r.year}{r.featured?.length ? ` · feat. ${r.featured.join(', ')}` : ''}{r.streams ? ` · ${fmt(r.streams)}` : ''}</span>
      </span>
      <button class="lr-row-play" data-slug={r.slug} aria-label={`Play ${r.title}`} title="Play preview">▶</button>
    </li>
  ))}
</ul>

<script type="application/json" id="lr-data" set:html={JSON.stringify(records)}></script>
<script is:inline>
  const initListeningRoom = () => {
    const wheelEl0 = document.getElementById('lr-wheel');
    if (!wheelEl0 || wheelEl0.dataset.init) return; // not on this page, or already bound
    wheelEl0.dataset.init = '1';
    const data = JSON.parse(document.getElementById('lr-data').textContent);
    let filtered = data.slice();

    // ── Rotary drag-to-spin wheel — live 1:1 drag, seamless 360° wrap, momentum ────
    // `pos` is a continuous position in cover-units (fractional, unbounded); covers sit on a ring
    // and each one's on-screen offset is the SHORTEST signed distance to `pos` (wrap-aware), so
    // there is no first/last edge — spinning one way loops forever. Drag tracks the pointer 1:1;
    // release flings with velocity, decays with friction, then springs to the nearest cover.
    const wheel = document.getElementById('lr-wheel');
    const wheelTrack = wheel.querySelector('.lr-wheel-track');
    let wheelList = [], pos = 0, vel = 0, wheelRaf = 0, currentRec = null;
    const N = () => wheelList.length;
    const ANGLE = 22;                                            // degrees between adjacent covers
    const radius = () => (window.innerWidth < 560 ? 230 : 340);
    const stepPx = () => (window.innerWidth < 560 ? 74 : 104);  // drag px per one cover
    const wrapOff = (idx) => { const n = N(); if (!n) return 99; let d = (((idx - pos) % n) + n) % n; if (d > n / 2) d -= n; return d; };
    const frontIdx = () => { const n = N(); return n ? (((Math.round(pos) % n) + n) % n) : 0; };
    const positionWheel = () => {
      const r = radius(), narrow = window.innerWidth < 560;
      wheelTrack.querySelectorAll('.lr-wheel-cover').forEach((el) => {
        const off = wrapOff(+el.dataset.idx), abs = Math.abs(off);
        if (abs > 3.4) { el.style.display = 'none'; return; }
        el.style.display = '';
        const th = off * ANGLE * Math.PI / 180;                 // this cover's angle on the ring
        const x = Math.sin(th) * r;
        const z = (Math.cos(th) - 1) * r;                       // front at 0, sides curve away/back
        const scale = Math.max(0.42, (narrow ? 1.05 : 1.16) - Math.min(abs, 4) * 0.145);
        el.style.transform = `translateX(${x.toFixed(1)}px) translateZ(${z.toFixed(1)}px) rotateY(${(-off * ANGLE).toFixed(1)}deg) scale(${scale.toFixed(3)})`;
        el.style.zIndex = String(200 - Math.round(abs * 12));
        el.style.opacity = String(abs > 2.6 ? 0.25 : 1);
        el.classList.toggle('front', Math.round(off) === 0);
      });
    };
    const fmtStreams = (n) => n ? (n >= 1000 ? (n / 1000).toFixed(n >= 1e5 ? 0 : 1) + 'K streams' : n + ' streams') : '';
    const fmtT = (t) => { if (!isFinite(t) || t < 0) t = 0; const m = Math.floor(t / 60), s = Math.floor(t % 60); return m + ':' + (s < 10 ? '0' : '') + s; };
    // Smart-link (Linkfire/Songwhip style): the in-page player is the instant teaser; real,
    // stream-counting plays happen on whichever platform the listener already subscribes to.
    // Exact track deep-links where we have IDs (Spotify, Apple); reliable search deep-links
    // elsewhere so the tap always lands on the song.
    const ARTIST = 'Lucius P. Thundercat';
    const streamLinks = (r) => {
      const q = encodeURIComponent(ARTIST + ' ' + r.title);
      const out = [['Spotify', r.trackId ? `https://open.spotify.com/track/${r.trackId}` : `https://open.spotify.com/album/${r.albumId}`]];
      out.push(['Apple Music', (r.appleTrackId && r.appleAlbumId) ? `https://music.apple.com/us/album/${r.appleAlbumId}?i=${r.appleTrackId}` : `https://music.apple.com/us/search?term=${q}`]);
      out.push(['YouTube Music', `https://music.youtube.com/search?q=${q}`]);
      out.push(['Deezer', `https://www.deezer.com/search/${q}`]);
      out.push(['Amazon Music', `https://music.amazon.com/search/${q}`]);
      out.push(['Tidal', `https://tidal.com/search?q=${q}`]);
      out.push(['SoundCloud', 'https://soundcloud.com/lpthrilla']);
      return out;
    };
    const fullButtons = (r) => {
      const items = streamLinks(r).map(([name, url]) => `<a class="lr-stream-link" href="${url}" target="_blank" rel="noopener">${name}</a>`).join('');
      return `<button class="lr-stream-toggle" type="button" aria-expanded="false">Streaming <span class="lr-stream-caret">▾</span></button><div class="lr-stream-menu" hidden>${items}</div>`;
    };
    // Load a record into the always-visible player (idle — does NOT start playback).
    const setInfo = (rec) => {
      if (!rec) return;
      currentRec = rec;
      document.getElementById('lr-title').textContent = rec.title;
      document.getElementById('lr-meta').textContent = [rec.year, fmtStreams(rec.streams)].filter(Boolean).join(' · ');
      const vc = document.getElementById('lr-vinyl-cover'); if (vc) { vc.src = rec.cover; vc.alt = rec.title + ' cover art'; }
      document.getElementById('lr-full').innerHTML = fullButtons(rec);
    };
    // As you spin, the player tracks the front record — but only while nothing is playing.
    const updateWheelLabel = () => { const a = document.getElementById('lr-audio'); if (!a || a.paused) setInfo(wheelList[frontIdx()]); };
    const renderWheel = (list) => {
      wheelList = list; pos = 0; vel = 0;
      wheelTrack.innerHTML = list.map((rec, i) => `<button class="lr-wheel-cover" type="button" tabindex="-1" data-slug="${rec.slug}" data-idx="${i}" aria-label="${rec.title.replace(/"/g, '')}"><img src="${rec.cover}" alt="${rec.title.replace(/"/g, '')} cover art" loading="lazy"></button>`).join('');
      positionWheel(); updateWheelLabel();
    };
    // Momentum + settle. Kept in the 'dragging' state (CSS transition off) so it's rAF-driven.
    const spin = () => {
      pos += vel; vel *= 0.94;
      if (Math.abs(vel) < 0.015) {                              // slow → spring to the nearest cover
        const target = Math.round(pos);
        pos += (target - pos) * 0.22;
        if (Math.abs(target - pos) < 0.002) { pos = target; wheel.classList.remove('dragging', 'fast'); positionWheel(); updateWheelLabel(); wheelRaf = 0; return; }
      }
      wheel.classList.toggle('fast', Math.abs(vel) > 0.3);      // motion-blur cue while spinning fast
      positionWheel();
      if (Math.abs(vel) > 0.3) updateWheelLabel();
      wheelRaf = requestAnimationFrame(spin);
    };
    let dragX = null, startPos = 0, lastPos = 0, moved = 0, downCover = null;
    wheel.addEventListener('pointerdown', (e) => {
      if (e.target.closest('.lr-wheel-arrow')) return;
      downCover = e.target.closest('.lr-wheel-cover'); // remember which cover was pressed (for tap-to-play)
      if (wheelRaf) { cancelAnimationFrame(wheelRaf); wheelRaf = 0; }
      dragX = e.clientX; startPos = pos; lastPos = pos; vel = 0; moved = 0;
      wheel.classList.add('dragging'); try { wheel.setPointerCapture(e.pointerId); } catch (_) {}
    });
    wheel.addEventListener('pointermove', (e) => {
      if (dragX == null) return;
      const dx = e.clientX - dragX; moved = Math.max(moved, Math.abs(dx));
      pos = startPos - dx / stepPx();                           // 1:1 live tracking
      vel = pos - lastPos; lastPos = pos;                       // instantaneous flick velocity
      wheel.classList.toggle('fast', Math.abs(vel) > 0.3);
      positionWheel();
    });
    // Release. A TAP (barely moved) plays/centres the pressed cover — handled HERE, not via a
    // click event, because setPointerCapture makes the browser fire click on the wheel, not the
    // cover, so a click listener never sees it. A real DRAG flings with momentum.
    const release = (e) => {
      if (dragX == null) return; dragX = null;
      try { if (e && e.pointerId != null) wheel.releasePointerCapture(e.pointerId); } catch (_) {}
      if (moved < 14 && downCover) {                            // a tap, not a drag — real mouse/trackpad clicks drift a few px
        wheel.classList.remove('dragging', 'fast');
        const idx = +downCover.dataset.idx; downCover = null;
        pos += wrapOff(idx); positionWheel();                   // glide the tapped cover to the front…
        playPreview(wheelList[idx]);                            // …and play it — any cover, not just the middle one
        return;
      }
      downCover = null;
      vel = Math.max(-1.5, Math.min(1.5, vel));                 // cap the fling
      if (!wheelRaf) wheelRaf = requestAnimationFrame(spin);
    };
    wheel.addEventListener('pointerup', release);
    wheel.addEventListener('pointercancel', release);
    // Arrows — secondary/accessible fallback: one smooth CSS-eased step (still wraps).
    const stepBy = (d) => { if (wheelRaf) { cancelAnimationFrame(wheelRaf); wheelRaf = 0; } wheel.classList.remove('dragging', 'fast'); pos = Math.round(pos) + d; positionWheel(); updateWheelLabel(); };
    wheel.querySelector('.prev').addEventListener('click', () => stepBy(-1));
    wheel.querySelector('.next').addEventListener('click', () => stepBy(1));
    wheel.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); stepBy(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); stepBy(1); }
      else if ((e.key === 'Enter' || e.key === ' ') && wheelList[frontIdx()]) { e.preventDefault(); playPreview(wheelList[frontIdx()]); }
    });
    window.addEventListener('resize', () => positionWheel(), { passive: true });

    // Pull → the platform's OWN track player FADES IN below the vinyl (the Spotify iframe is the
    // audio; no Web Audio, no native taste). Track-level (embed/track/<id>) so a logged-in play
    // counts as a real stream — never an album/artist embed. A small toggle switches to Apple.
    // ── Player: instant 30s preview via a native <audio> (the Spotify iframe can't autoplay for
    //    logged-out users). The record + transport are ALWAYS visible, idle until you play. 'Full
    //    track' loads the Spotify/Apple embed on demand (counts a stream). ──
    const audio = document.getElementById('lr-audio');
    const player = document.getElementById('lr-player');
    const playBtn = document.getElementById('lr-playpause');
    const markPlaying = () => wheelTrack.querySelectorAll('.lr-wheel-cover').forEach((el) => el.classList.toggle('playing', currentRec && el.dataset.slug === currentRec.slug));
    // Expand/collapse the "Streaming" submenu of platform links. open=true forces open.
    const openStreamMenu = (open) => {
      const tog = document.querySelector('.lr-stream-toggle'), menu = document.querySelector('.lr-stream-menu');
      if (!tog || !menu) return;
      const willOpen = open == null ? menu.hidden : open;
      tog.setAttribute('aria-expanded', String(willOpen)); menu.hidden = !willOpen;
    };
    // Start the preview IMMEDIATELY (called inside the click/tap gesture → autoplay is allowed).
    // No preview file → surface the streaming links so they can hear the full song on a platform.
    const playPreview = (r) => {
      if (!r) return;
      setInfo(r); markPlaying();
      if (window.SVR) window.SVR.stop();
      if (!r.previewUrl) { openStreamMenu(true); return; }
      if (audio.getAttribute('src') !== r.previewUrl) audio.setAttribute('src', r.previewUrl);
      audio.currentTime = 0; audio.play().catch(() => {});
    };
    const togglePlay = () => {
      if (!currentRec) return;
      if (!currentRec.previewUrl) { openStreamMenu(true); return; }
      if (audio.paused) playPreview(currentRec); else audio.pause();
    };
    document.getElementById('lr-vinyl').addEventListener('click', togglePlay);
    playBtn.addEventListener('click', togglePlay);
    document.getElementById('lr-full').addEventListener('click', (e) => {
      if (e.target.closest('.lr-stream-toggle')) { openStreamMenu(); return; } // links navigate themselves
    });
    document.getElementById('lr-scrub').addEventListener('pointerdown', (e) => { const rc = e.currentTarget.getBoundingClientRect(); if (audio.duration) audio.currentTime = Math.max(0, Math.min(1, (e.clientX - rc.left) / rc.width)) * audio.duration; });
    audio.addEventListener('play', () => { player.classList.add('playing'); playBtn.textContent = '⏸'; playBtn.setAttribute('aria-label', 'Pause'); markPlaying(); });
    audio.addEventListener('pause', () => { player.classList.remove('playing'); playBtn.textContent = '▶'; playBtn.setAttribute('aria-label', 'Play'); });
    audio.addEventListener('ended', () => { player.classList.remove('playing'); playBtn.textContent = '▶'; playBtn.setAttribute('aria-label', 'Play'); });
    audio.addEventListener('timeupdate', () => { const d = audio.duration || 30; document.getElementById('lr-fill').style.width = (audio.currentTime / d * 100) + '%'; document.getElementById('lr-cur').textContent = fmtT(audio.currentTime); });
    audio.addEventListener('loadedmetadata', () => { document.getElementById('lr-dur').textContent = fmtT(audio.duration); });

    const spinToSlug = (slug) => {                              // bring a record to the front (list / deep-link)
      const idx = wheelList.findIndex((x) => x.slug === slug);
      if (idx < 0) return null;
      if (wheelRaf) { cancelAnimationFrame(wheelRaf); wheelRaf = 0; }
      pos += wrapOff(idx); wheel.classList.remove('dragging'); positionWheel();
      return wheelList[idx];
    };
    const applyFilter = (mood) => {
      filtered = mood === 'all' ? data.slice() : data.filter((r) => r.moods.includes(mood));
      if (!filtered.length) filtered = data.slice();
      renderWheel(filtered);
      audio.pause(); setInfo(wheelList[frontIdx()]); markPlaying(); // reset the player to the new front record
    };
    document.querySelectorAll('.lr-chip').forEach((chip) => chip.addEventListener('click', () => {
      document.querySelectorAll('.lr-chip').forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true'); applyFilter(chip.dataset.mood);
    }));
    // Full-list rows play instantly too — spin the wheel to that record if present, then play.
    const playFromList = (slug) => playPreview(spinToSlug(slug) || data.find((x) => x.slug === slug));
    document.querySelectorAll('.lr-row-play').forEach((b) => b.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); playFromList(b.dataset.slug); }));
    document.querySelectorAll('.lr-row').forEach((row) => row.addEventListener('click', (e) => { if (e.target.closest('a')) return; playFromList(row.dataset.slug); }));

    applyFilter('all'); // opens on Everything; the player sits idle on the front record
    // deep link: /#slug brings that record to the front + plays it
    if (location.hash.length > 1) { const s = decodeURIComponent(location.hash.slice(1)); if (data.some((r) => r.slug === s)) playFromList(s); }
  };
  initListeningRoom();
  document.addEventListener('astro:page-load', initListeningRoom);
</script>
