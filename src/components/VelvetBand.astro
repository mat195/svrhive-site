---
// Counter-Velvet Banner — a thick full-bleed band of the REAL photographed velvet scan,
// luminance-remapped toward the Ribbon (#7a3b4f) counter-tone. A deliberate visual anchor at a
// structural break. Shown large + rich (no dimming overlay) so the weave reads as actual fabric.
// Content on the fabric is one of: a Spotify TRACK embed (functional, `trackId`), a sparse Cream
// label (`label`), or pure texture (neither). The embed uses the same per-track pattern as the
// rest of the site (embed/track/<id>) — never album/artist — so it stays a single source of truth.
export interface Props {
  trackId?: string; // Spotify track id → a working track player sits on the velvet
  label?: string;   // optional sparse Cream line (selvedge-style tag)
  height?: number;  // band thickness in px
}
const { trackId, label, height = 210 } = Astro.props;
const decorative = !trackId && !label;
---
<section class="velvet-band" style={`--band-h:${height}px`} role={decorative ? 'presentation' : undefined} aria-hidden={decorative ? 'true' : undefined}>
  {trackId ? (
    <div class="velvet-embed-wrap">
      <iframe class="velvet-embed" src={`https://open.spotify.com/embed/track/${trackId}`} width="100%" height="152" frameborder="0" allow="autoplay; encrypted-media; clipboard-write; fullscreen; picture-in-picture" loading="lazy" title="Featured track"></iframe>
    </div>
  ) : label ? (
    <span class="velvet-band-label">{label}</span>
  ) : null}
</section>
