---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { LABEL_NAME, SITE, absolute, entity } from '../lib/entity';
const streamLinks = (entity.links ?? []).filter((l: any) => /spotify|apple|bandcamp|soundcloud|youtube/i.test(l.url)).slice(0, 5);

export interface Props {
  title: string;
  description: string;
  path: string; // e.g. "/lucius-p-thundercat/"
  jsonld?: string; // serialized @graph
  ogType?: string;
  noindex?: boolean; // private/unlisted pages (e.g. the internal press kit)
}

const { title, description, path, jsonld, ogType = 'website', noindex = false } = Astro.props;
const canonical = absolute(path);
const nav = [
  { href: '/', label: 'Label' },
  { href: '/lucius-p-thundercat/', label: 'Lucius P. Thundercat' },
  { href: '/listen/', label: 'Listen' },
  { href: '/contact/', label: 'Contact' },
];
const isCurrent = (href: string) => href === path;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ClientRouter />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <link rel="canonical" href={canonical} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={LABEL_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    {jsonld && <script type="application/ld+json" set:html={jsonld} />}
  </head>
  <body>
    <div id="sheen" aria-hidden="true"></div>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/"><span class="mark" aria-hidden="true"></span>{LABEL_NAME}</a>
        <nav class="primary" aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href} aria-current={isCurrent(n.href) ? 'page' : undefined}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>

    <!-- Privacy-first analytics beacon (non-content; page reads fine without JS). -->
    <script src="/analytics.js" defer></script>

    <footer class="site-footer">
      <div class="wrap">
        <div class="foot-grid">
          <div>
            <span class="f-brand"><span class="mark" aria-hidden="true"></span>{LABEL_NAME}</span>
            <p class="muted" style="margin:0.6rem 0 0;">Independent record label · home of Lucius P. Thundercat<br />Montréal, Québec, Canada</p>
          </div>
          <div>
            {streamLinks.length > 0 && (
              <div class="f-links">
                {streamLinks.map((l: any) => <a href={l.url} target="_blank" rel="noopener">{l.label ?? 'Listen'}</a>)}
              </div>
            )}
            <p class="muted" style="margin:0.7rem 0 0;"><a href="/contact/">Contact</a> · <a href={SITE}>silkvelvetrecords.com</a></p>
          </div>
        </div>
        <p class="copy">© {new Date().getFullYear()} {LABEL_NAME}. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline>
      // Full-viewport mouse-reactive sheen (Deep Velvet). The #sheen layer is fixed and
      // full-bleed; we set --mx/--my in viewport % on the document root, so the glow
      // follows the cursor everywhere with no bounded edge. Bound once (survives view
      // transitions). Off under reduced-motion.
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches && !window.__sheen) {
        window.__sheen = 1;
        addEventListener('pointermove', (e) => {
          document.documentElement.style.setProperty('--mx', `${(e.clientX / innerWidth) * 100}%`);
          document.documentElement.style.setProperty('--my', `${(e.clientY / innerHeight) * 100}%`);
        }, { passive: true });
      }
    </script>
  </body>
</html>
