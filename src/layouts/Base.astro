---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { LABEL_NAME, SITE, absolute, entity } from '../lib/entity';
const streamLinks = (entity.links ?? []).filter((l: any) => /spotify|apple|soundcloud|youtube/i.test(l.url)).slice(0, 5);

export interface Props {
  title: string;
  description: string;
  path: string; // e.g. "/lucius-p-thundercat/"
  jsonld?: string; // serialized @graph
  ogType?: string;
  noindex?: boolean; // private/unlisted pages (e.g. the internal press kit)
}

const { title, description, path, jsonld, ogType = 'website', noindex = false } = Astro.props;
const canonical = absolute(path);
const nav = [
  { href: '/', label: 'Listen' },
  { href: '/lucius-p-thundercat/', label: 'Lucius P. Thundercat' },
  { href: '/contact/', label: 'Contact' },
];
const isCurrent = (href: string) => href === path;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ClientRouter />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <link rel="canonical" href={canonical} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={LABEL_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    {jsonld && <script type="application/ld+json" set:html={jsonld} />}
  </head>
  <body>
    <div id="sheen" aria-hidden="true"></div>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/" aria-label={LABEL_NAME}><img class="brand-logo" src="/assets/svr-glass-plate-logo.png" alt={LABEL_NAME} width="1795" height="1721" /></a>
        <nav class="primary" aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href} aria-current={isCurrent(n.href) ? 'page' : undefined}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>

    {/* Native audio player — one shared <audio> + a floating transport bar in our own
        design language (Velvet/Underfelt surface, Silk-gold progress, mono timestamps,
        Instrument Serif title). Clicking any [data-preview] cover site-wide plays its 30s
        preview instantly; covers with no preview show an in-theme "Listen on Spotify" state.
        No Spotify iframe anywhere. Persists across view transitions so playback survives nav. */}
    <div id="svr-player" class="svr-player" hidden transition:persist>
      <img id="svr-p-cover" class="svr-p-cover" alt="" />
      <button id="svr-p-toggle" class="svr-p-toggle" type="button" aria-label="Pause">‖</button>
      <div class="svr-p-main">
        <div class="svr-p-title" id="svr-p-title"></div>
        <div class="svr-p-transport">
          <span class="svr-p-time" id="svr-p-cur">0:00</span>
          <div class="svr-p-scrub" id="svr-p-scrub" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0"><div class="svr-p-fill" id="svr-p-fill"></div></div>
          <span class="svr-p-time" id="svr-p-dur">0:30</span>
        </div>
        <div class="svr-p-note" id="svr-p-note">Hear the full track:</div>
      </div>
      <a class="svr-p-spotify" id="svr-p-spotify" href="#" target="_blank" rel="noopener">Spotify ↗</a>
      <a class="svr-p-apple" id="svr-p-apple" href="#" target="_blank" rel="noopener" hidden>Apple Music ↗</a>
      <button id="svr-p-close" class="svr-p-close" type="button" aria-label="Close player">✕</button>
    </div>
    <audio id="svr-audio" preload="none" transition:persist></audio>
    <script is:inline>
      (function () {
        if (window.SVR) return;
        // The Listening Room can live at any URL (it's the root front door now). Detect it by the
        // crate's presence, not the path — so the site-wide cover-play defers to the deck there.
        var onListen = function () { return !!document.getElementById('lr-crate'); };
        var fmt = function (t) { if (!isFinite(t) || t < 0) t = 0; var m = Math.floor(t / 60), s = Math.floor(t % 60); return m + ':' + (s < 10 ? '0' : '') + s; };
        var $ = function (id) { return document.getElementById(id); };
        var SVR = {
          current: null, _trigger: null,
          audio: function () { return $('svr-audio'); },
          // opts: { src, title, cover, spotify, trigger }. No src → in-theme "Listen on Spotify".
          play: function (opts) {
            var a = this.audio(); if (!a) return;
            if (this.current && opts.src && this.current.src === opts.src && !a.paused) { a.pause(); return; } // toggle same track
            if (this._trigger && this._trigger !== opts.trigger) this._trigger.classList.remove('playing');
            this._trigger = opts.trigger || null;
            this.current = opts;
            if (opts.src) { if (a.getAttribute('src') !== opts.src) { a.setAttribute('src', opts.src); } a.currentTime = 0; a.play().catch(function () {}); }
            else { a.pause(); a.removeAttribute('src'); }
            this._render();
            document.dispatchEvent(new CustomEvent('svr:change', { detail: opts }));
          },
          toggle: function () { var a = this.audio(); if (!a || !this.current || !this.current.src) return; if (a.paused) a.play().catch(function () {}); else a.pause(); },
          stop: function () { var a = this.audio(); if (a) a.pause(); if (this._trigger) this._trigger.classList.remove('playing'); this._trigger = null; this.current = null; var bar = $('svr-player'); if (bar) bar.hidden = true; },
          _render: function () {
            var bar = $('svr-player'); if (!bar) return;
            var c = this.current || {};
            $('svr-p-title').textContent = c.title || '';
            var cover = $('svr-p-cover'); if (c.cover) { cover.src = c.cover; cover.style.display = ''; } else { cover.style.display = 'none'; }
            var sp = $('svr-p-spotify'); if (c.spotify) { sp.href = c.spotify; sp.hidden = false; } else { sp.hidden = true; }
            var ap = $('svr-p-apple'); if (ap) { if (c.apple) { ap.href = c.apple; ap.hidden = false; } else { ap.hidden = true; } }
            bar.classList.toggle('no-preview', !c.src);
            bar.hidden = false; // the floating bottom bar is the transport everywhere, room included

          }
        };
        window.SVR = SVR;

        function bindAudio() {
          var a = SVR.audio(); if (!a || a.__bound) return; a.__bound = true;
          a.addEventListener('timeupdate', function () {
            var pct = a.duration ? (a.currentTime / a.duration * 100) : 0;
            var f = $('svr-p-fill'); if (f) f.style.width = pct + '%';
            var cur = $('svr-p-cur'); if (cur) cur.textContent = fmt(a.currentTime);
            var scrub = $('svr-p-scrub'); if (scrub) scrub.setAttribute('aria-valuenow', Math.round(pct));
          });
          a.addEventListener('loadedmetadata', function () { var d = $('svr-p-dur'); if (d) d.textContent = fmt(a.duration); });
          a.addEventListener('play', function () { var t = $('svr-p-toggle'); if (t) { t.textContent = '‖'; t.setAttribute('aria-label', 'Pause'); } if (SVR._trigger) SVR._trigger.classList.add('playing'); });
          a.addEventListener('pause', function () { var t = $('svr-p-toggle'); if (t) { t.textContent = '▶'; t.setAttribute('aria-label', 'Play'); } if (SVR._trigger) SVR._trigger.classList.remove('playing'); });
          a.addEventListener('ended', function () { var t = $('svr-p-toggle'); if (t) { t.textContent = '▶'; t.setAttribute('aria-label', 'Play'); } if (SVR._trigger) SVR._trigger.classList.remove('playing'); });
        }
        bindAudio();
        document.addEventListener('astro:page-load', function () { bindAudio(); if (SVR.current) SVR._render(); });

        // Floating-bar controls (delegated so they survive persist across nav).
        document.addEventListener('click', function (e) {
          var tgt = e.target;
          if (tgt.closest && tgt.closest('#svr-p-toggle')) { SVR.toggle(); return; }
          if (tgt.closest && tgt.closest('#svr-p-close')) { SVR.stop(); return; }
          if (tgt.closest && (tgt.closest('#svr-p-spotify') || tgt.closest('#svr-p-apple'))) { return; } // let the platform link open
          var scrub = tgt.closest && tgt.closest('#svr-p-scrub');
          if (scrub) { var a = SVR.audio(); if (a && a.duration) { var r = scrub.getBoundingClientRect(); a.currentTime = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width)) * a.duration; } return; }
          // Site-wide cover play (skip /listen/, which drives the player through its deck).
          if (onListen()) return;
          var el = tgt.closest ? tgt.closest('[data-preview],[data-album]') : null;
          if (!el) return;
          e.preventDefault(); e.stopPropagation();
          var img = el.querySelector('img');
          var title = (el.getAttribute('data-title') || (img && img.alt) || '').replace(/ cover art$/, '');
          var album = el.getAttribute('data-album'), track = el.getAttribute('data-track');
          var aTrack = el.getAttribute('data-apple-track'), aAlbum = el.getAttribute('data-apple-album');
          SVR.play({
            src: el.getAttribute('data-preview') || '', title: title, cover: (img && img.src) || '',
            spotify: track ? ('https://open.spotify.com/track/' + track) : (album ? ('https://open.spotify.com/album/' + album) : ''),
            apple: (aTrack && aAlbum) ? ('https://music.apple.com/us/album/' + aAlbum + '?i=' + aTrack) : '',
            trigger: el });
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') { SVR.stop(); return; }
          if (onListen()) return;
          if ((e.key === 'Enter' || e.key === ' ') && e.target && e.target.matches && e.target.matches('[data-preview],[data-album]')) {
            e.preventDefault(); e.target.click();
          }
        });
      })();
    </script>

    <!-- Privacy-first analytics beacon (non-content; page reads fine without JS). -->
    <script src="/analytics.js" defer></script>

    <footer class="site-footer">
      <div class="wrap">
        <div class="foot-grid">
          <div>
            <span class="f-brand"><span class="mark" aria-hidden="true"></span>{LABEL_NAME}</span>
            <p class="muted" style="margin:0.6rem 0 0;">Independent record label · home of Lucius P. Thundercat<br />Montréal, Québec, Canada</p>
          </div>
          <div>
            {streamLinks.length > 0 && (
              <div class="f-links">
                {streamLinks.map((l: any) => <a href={l.url} target="_blank" rel="noopener">{l.label ?? 'Listen'}</a>)}
              </div>
            )}
            <p class="muted" style="margin:0.7rem 0 0;"><a href="/contact/">Contact</a> · <a href={SITE}>silkvelvetrecords.com</a></p>
          </div>
        </div>
        <p class="copy">© {new Date().getFullYear()} {LABEL_NAME}. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline>
      // Full-viewport mouse-reactive sheen (Deep Velvet). The #sheen layer is fixed and
      // full-bleed; we set --mx/--my in viewport % on the document root, so the glow
      // follows the cursor everywhere with no bounded edge. Bound once (survives view
      // transitions). Off under reduced-motion.
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches && !window.__sheen) {
        window.__sheen = 1;
        addEventListener('pointermove', (e) => {
          document.documentElement.style.setProperty('--mx', `${(e.clientX / innerWidth) * 100}%`);
          document.documentElement.style.setProperty('--my', `${(e.clientY / innerHeight) * 100}%`);
        }, { passive: true });
      }
    </script>
  </body>
</html>
